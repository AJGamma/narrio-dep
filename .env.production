# Production Environment Variables for Backend
# Copy this file to .env.production.local and update the values

# CORS Configuration - REQUIRED
# Comma-separated list of allowed frontend origins
# Example: https://narrio.example.com,https://www.narrio.example.com
NARRIO_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Logging Configuration
NARRIO_LOG_LEVEL=INFO

# Add other environment variables as needed based on your .narrio.yaml.example
